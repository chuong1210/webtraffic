# Traffic Monitor API – example environment
# Copy to .env and adjust as needed

# Server
DEBUG=false
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated or leave default)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Detection defaults
CONF_THRESHOLD=0.35
LINE_POSITION=0.55
MAX_FPS=30

# Auto-load this model on startup if present in models_storage (empty = skip)
DEFAULT_MODEL=best.pt

# Paths are relative to app working directory (e.g. backend/ when running locally)
# MODELS_DIR=models_storage
# UPLOADS_DIR=uploads
